<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ME3Server_WV"
             x:Class="ME3Server_WV.GUI_Log">
    <ScrollViewer x:Name="logScrollViewer" HorizontalScrollBarVisibility="Auto">
        <SelectableTextBlock x:Name="logTextBlock"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="12"
                             TextWrapping="NoWrap"
                             Margin="4"/>
    </ScrollViewer>
</UserControl>
