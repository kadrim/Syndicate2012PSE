<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ME3Server_WV.GUI_GameList">
    <Grid RowDefinitions="*,5,*">
        <ListBox x:Name="listBox1" Grid.Row="0"
                 FontFamily="Consolas, Courier New, monospace" FontSize="12"
                 SelectionChanged="listBox1_SelectionChanged"/>
        <GridSplitter Grid.Row="1" ResizeDirection="Rows" Background="Gray"/>
        <TextBox x:Name="rtb1" Grid.Row="2" IsReadOnly="True" AcceptsReturn="True"
                 FontFamily="Consolas, Courier New, monospace" FontSize="12"
                 TextWrapping="NoWrap"/>
    </Grid>
</UserControl>
